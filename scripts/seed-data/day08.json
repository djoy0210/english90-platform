  "lessonContent": {
    "page1": {
      "grammarTopic": "Wh- Questions — What / When / Where / Who / Why / How",
      "grammarExplanation": "Wh- questions ask for specific information — NOT just yes or no. They begin with: What (юу/ямар), When (хэзээ), Where (хаана), Who (хэн), Why (яагаад), How (яаж). The question word comes FIRST, then the auxiliary verb (do/does/is/are), then the subject. Example: 'Where DO you live?' 'When DOES she wake up?' 'What IS today?' Wh- асуултууд тодорхой мэдээлэл шаарддаг — зөвхөн тийм/үгүй биш. Дараалал: Асуулт үг → туслах үйл үг → субьект → үндсэн үйл үг.",
      "grammarTable": [
        { "subject": "What", "verb": "is/do", "positive": "What is today?", "negative": "It is Monday.", "question": "What do you eat?", "mongolian": "Юу / Ямар" },
        { "subject": "When", "verb": "is/does", "positive": "When is your birthday?", "negative": "It is in June.", "question": "When do you study?", "mongolian": "Хэзээ" },
        { "subject": "Where", "verb": "is/do", "positive": "Where is the school?", "negative": "It is near here.", "question": "Where do you live?", "mongolian": "Хаана" },
        { "subject": "Who", "verb": "is", "positive": "Who is your teacher?", "negative": "She is Ms. Bold.", "question": "Who is that person?", "mongolian": "Хэн" },
        { "subject": "Why", "verb": "do/are", "positive": "Why do you study?", "negative": "Because I like it.", "question": "Why are you late?", "mongolian": "Яагаад" },
        { "subject": "How", "verb": "do/are", "positive": "How are you?", "negative": "I am fine.", "question": "How do you go to school?", "mongolian": "Яаж" }
      ],
