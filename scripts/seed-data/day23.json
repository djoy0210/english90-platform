  "lessonContent": {
    "page1": {
      "grammarTopic": "Past Simple — regular verbs (-ed endings)",
      "grammarExplanation": "Regular verbs form the Past Simple by adding -ED to the base verb. Rules: 1) Most verbs: just add -ed → walk→walked, talk→talked. 2) Verbs ending in -e: add only -d → arrive→arrived, love→loved. 3) Verbs ending in consonant+y: change y→ied → study→studied, try→tried. 4) Short verbs with vowel+consonant: double the last letter → stop→stopped, plan→planned. For NEGATIVES use DIDN'T + base verb. For QUESTIONS use DID + subject + base verb. Ердийн үйл үгс өнгөрсөн цагт -ED нэмдэг. Дүрэм: 1) Ихэнх үйл үгэнд -ed нэм → walk→walked. 2) -e-ээр төгссөнд -d нэм → arrive→arrived. 3) Гийгүүлэгч+y→ied болгоно → study→studied. 4) Богино үйл үгийн эцсийн гийгүүлэгчийг давтана → stop→stopped. Үгүйсгэлд DIDN'T + үндсэн үйл үг. Асуултад DID + субьект + үндсэн үйл үг.",
      "grammarTable": [
        { "subject": "I", "verb": "walk → walked", "positive": "I walked to school.", "negative": "I didn't walk.", "question": "Did you walk?", "mongolian": "явсан" },
        { "subject": "She", "verb": "study → studied", "positive": "She studied all night.", "negative": "She didn't study.", "question": "Did she study?", "mongolian": "суралцсан" },
        { "subject": "We", "verb": "arrive → arrived", "positive": "We arrived early.", "negative": "We didn't arrive early.", "question": "Did you arrive?", "mongolian": "ирсэн" },
        { "subject": "He", "verb": "stop → stopped", "positive": "He stopped running.", "negative": "He didn't stop.", "question": "Did he stop?", "mongolian": "зогссон" },
        { "subject": "They", "verb": "play → played", "positive": "They played football.", "negative": "They didn't play.", "question": "Did they play?", "mongolian": "тоглосон" },
        { "subject": "I", "verb": "finish → finished", "positive": "I finished my homework.", "negative": "I didn't finish.", "question": "Did you finish?", "mongolian": "дуусгасан" }
